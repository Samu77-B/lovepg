# =============================================================================
# Documentation Directory Security - Love Palmers Green
# Block web access to documentation files
# =============================================================================

# DENY ALL ACCESS - Documentation should not be publicly accessible
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Disable directory browsing
Options -Indexes

# Disable script execution
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
