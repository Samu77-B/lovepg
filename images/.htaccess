# =============================================================================
# Images Directory Security - Love Palmers Green
# =============================================================================

# Disable directory browsing
Options -Indexes

# Disable symlinks
Options -FollowSymLinks
Options +SymLinksIfOwnerMatch

# BLOCK PHP EXECUTION - Critical for preventing uploaded shell scripts
<FilesMatch "\.ph(p[345]?|t|tml|ar)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block other potentially dangerous extensions
<FilesMatch "\.(cgi|pl|py|sh|bash|exe|dll|asp|aspx|shtml|phtml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Only allow legitimate image file types
<FilesMatch "\.(?!(jpg|jpeg|png|gif|webp|svg|ico|bmp)$)">
    # Allow only specific extensions - commented out to not break other valid files
    # Uncomment if you want strict image-only access
    # Require all denied
</FilesMatch>

# Set proper content types to prevent MIME confusion attacks
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# Disable script execution via Apache handler
RemoveHandler .php .phtml .php3 .php4 .php5 .phps .phar
RemoveType .php .phtml .php3 .php4 .php5 .phps .phar

<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Force download instead of execution for any script files that slip through
<IfModule mod_headers.c>
    <FilesMatch "\.(php|phtml|php3|php4|php5)$">
        Header set Content-Disposition attachment
        Header set Content-Type "application/octet-stream"
    </FilesMatch>
</IfModule>
