# =============================================================================
# Uploads Directory Security - CRITICAL PROTECTION
# This folder is a prime target for malware uploads
# =============================================================================

# Disable directory browsing
Options -Indexes

# Disable symlinks
Options -FollowSymLinks
Options +SymLinksIfOwnerMatch

# COMPLETELY BLOCK PHP EXECUTION
<FilesMatch "\.">
    <IfModule mod_php.c>
        php_flag engine off
    </IfModule>
</FilesMatch>

# Block ALL executable file types
<FilesMatch "\.(ph(p[345]?|t|tml|ar)|cgi|pl|py|sh|bash|exe|dll|asp|aspx|shtml|phtml|htaccess|htpasswd)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Remove handlers completely
RemoveHandler .php .phtml .php3 .php4 .php5 .phps .phar .cgi .pl .py
RemoveType .php .phtml .php3 .php4 .php5 .phps .phar .cgi .pl .py

# Block double extensions like image.jpg.php
<FilesMatch ".*\..*\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Set proper content types
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# Force download for any PHP files that somehow exist
<IfModule mod_headers.c>
    <FilesMatch "\.(php|phtml|php3|php4|php5)$">
        Header set Content-Disposition attachment
        Header set Content-Type "application/octet-stream"
    </FilesMatch>
</IfModule>
