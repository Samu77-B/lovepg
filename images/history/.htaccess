# =============================================================================
# History Images Directory Security - Love Palmers Green
# =============================================================================

# Disable directory browsing
Options -Indexes

# Disable symlinks
Options -FollowSymLinks
Options +SymLinksIfOwnerMatch

# BLOCK PHP EXECUTION
<FilesMatch "\.(ph(p[345]?|t|tml|ar)|cgi|pl|py|sh|bash|exe|dll|asp|aspx|shtml|phtml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Remove script handlers
RemoveHandler .php .phtml .php3 .php4 .php5 .phps .phar
RemoveType .php .phtml .php3 .php4 .php5 .phps .phar

<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Set proper content type
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
